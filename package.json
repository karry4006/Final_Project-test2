{
  "name": "final-project-fullstack",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "init-db": "node server/init-db.js",
    "start": "node server.js",
    "dev:server": "node server/server.js",
    "dev:client": "npm run dev --prefix client",
    "build:client": "npm run build --prefix client",
    "build": "npm run build:client",
    "azure:setup": "npm install --prefix client --include=dev && npm run build:client",
    "postinstall": "npm run azure:setup",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\""
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "express": "^5.2.1",
    "sqlite3": "^6.0.1"
  }
}
